# === REQUIRED ===
# Base URL of your Convex HTTP deployment (e.g. https://famous-albatross-420.convex.site)
CONVEX_SITE_URL=https://famous-albatross-420.convex.site

# API key set in Convex via: npx convex env set HUNTER_API_KEY <your-key>
HUNTER_API_KEY=your_hunter_api_key_here

# === OPTIONAL ===
# Residential proxy URL (Bright Data, Smartproxy, etc.)
# Format: http://user:password@proxy-host:port
# PROXY_URL=http://user:pass@proxy.example.com:8000

# Set to "true" to simulate sessions without actually booking slots
# DRY_RUN=true
